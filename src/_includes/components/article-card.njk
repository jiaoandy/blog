<article class="article-card">
  <h2 class="card-title">
    <a href="{{ post.url }}">{{ post.data.title }}</a>
  </h2>

  {% if theme.showDateOnCards and post.date %}
    <time class="card-date" datetime="{{ post.date | isoDate }}">
      {{ post.date | formatDate(site.dateFormat) }}
    </time>
  {% endif %}

  {% if post.data.description %}
    <p class="card-description">{{ post.data.description }}</p>
  {% endif %}

  {% if theme.showTagsOnCards and post.data.tags and post.data.tags | length %}
    <div class="card-tags">
      {% for tag in post.data.tags %}
        {% include "components/tag-badge.njk" %}
      {% endfor %}
    </div>
  {% endif %}
</article>
