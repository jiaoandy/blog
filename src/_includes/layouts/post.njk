---
layout: layouts/base
---
<article class="post">
  <header class="post-header">
    <h1 class="post-title">{{ title }}</h1>
    <div class="post-meta">
      {% if date %}
        <time class="post-date" datetime="{{ date | isoDate }}">{{ date | formatDate(site.dateFormat) }}</time>
      {% endif %}
      {% if tags and tags | length %}
        {% include "components/tag-list.njk" %}
      {% endif %}
    </div>
  </header>
  <div class="post-content">
    {{ content | safe }}
  </div>
</article>

{% if modules.recentPosts.enabled %}
  {% include "modules/recent-posts/recent-posts.njk" %}
{% endif %}
