<!DOCTYPE html>
<html lang="{{ site.defaultLanguage | default('zh-CN') }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description | default(site.description) }}">
  <title>{% if title %}{{ title }} — {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>

  {# SEO meta tags #}
  <meta property="og:title" content="{% if title %}{{ title }} — {{ site.title }}{% else %}{{ site.title }}{% endif %}">
  <meta property="og:description" content="{{ description | default(site.description) }}">
  <meta property="og:type" content="{% if pageType == 'post' %}article{% else %}website{% endif %}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:site_name" content="{{ site.title }}">
  {% if ogImage %}<meta property="og:image" content="{{ site.url }}{{ ogImage }}">{% endif %}

  {# RSS feed #}
  <link rel="alternate" type="application/atom+xml" title="{{ site.title }} Feed" href="/feed.xml">

  <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
  {% include "components/header.njk" %}

  <main class="main-content">
    {% block content %}
      {{ content | safe }}
    {% endblock %}
  </main>

  {% include "components/footer.njk" %}

  <script src="/assets/js/main.js"></script>
</body>
</html>
