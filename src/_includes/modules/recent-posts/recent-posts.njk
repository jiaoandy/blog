<aside class="module module--recent-posts">
  <h3 class="module-title">最新文章</h3>
  <ul class="recent-posts-list">
    {% for post in collections.posts | first(modules.recentPosts.count) %}
      <li class="recent-posts-item">
        <a href="{{ post.url }}">{{ post.data.title }}</a>
        {% if theme.showDateOnCards and post.date %}
          <time datetime="{{ post.date | isoDate }}">{{ post.date | formatDate(site.dateFormat) }}</time>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
</aside>
