---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title }}</title>
  <subtitle>{{ site.description }}</subtitle>
  <link href="{{ site.url }}/feed.xml" rel="self"/>
  <link href="{{ site.url }}/"/>
  <updated>{{ collections.posts[0].date | isoDate if collections.posts | length else "" }}</updated>
  <id>{{ site.url }}/</id>
  <author>
    <name>{{ site.author.name }}</name>
    {% if site.author.email %}<email>{{ site.author.email }}</email>{% endif %}
  </author>
  {% for post in collections.posts %}
  <entry>
    <title>{{ post.data.title }}</title>
    <link href="{{ site.url }}{{ post.url }}"/>
    <updated>{{ post.date | isoDate }}</updated>
    <id>{{ site.url }}{{ post.url }}</id>
    <summary>{{ post.data.description | default("") }}</summary>
    {% for tag in post.data.tags %}
    <category term="{{ tag }}"/>
    {% endfor %}
  </entry>
  {% endfor %}
</feed>
